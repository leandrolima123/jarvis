{
  "manifest": {
    "manifestVersion": "1.0",
    "apis": {
      "custom": {
        "endpoint": {
          "sourceDir": "lambda",
          "uri": "ask-custom-jarvis-default"
        },
        "interfaces": []
      }
    },
    "publishingInformation": {
      "distributionCountries": [],
      "isAvailableWorldwide": true,
      "locales": {
        "pt-BR": {
          "name": "jarvis",
          "summary": "Assistente Jarvis com Gemini",
          "description": "Converse com o Jarvis e faça perguntas sobre qualquer assunto.",
          "examplePhrases": [
            "Alexa, abra modo jarvis",
            "Alexa, abra modo jarvis e pergunte o que é inteligência artificial"
          ],
          "keywords": [
            "jarvis",
            "assistente",
            "gemini"
          ]
        }
      },
      "testingInstructions": "Diga Alexa, abra modo jarvis e faça uma pergunta.",
      "category": "KNOWLEDGE_AND_TRIVIA"
    },
    "privacyAndCompliance": {
      "allowsPurchases": false,
      "usesPersonalInfo": false,
      "isChildDirected": false,
      "isExportCompliant": true,
      "containsAds": false,
      "locales": {
        "pt-BR": {
          "privacyPolicyUrl": "https://github.com/leandrolima123/jarvis"
        }
      }
    }
  }
}
